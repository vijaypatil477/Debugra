# ── Firebase (required — get these from Firebase Console) ──────────
# 1. Go to https://console.firebase.google.com → Create a project (or select existing)
# 2. Enable Authentication (at least Email/Password and/or Google)
# 3. Create a Firestore Database
# 4. Project Settings → General → Your apps → Web app → copy the config values below
#    If the Web app snippet uses "measurementId" you can leave it out — it's not required.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API URL (for local dev leave as-is, for production use your deployed URL)
VITE_API_URL=http://localhost:3001

# ── Backend ────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSP_REPORT_URI=/api/security/csp-report

# Get a free Groq API key at https://console.groq.com
GROQ_API_KEY=

# Used for /api/admin/memory-profile diagnostic endpoints
DEBUGRA_ADMIN_TOKEN=

# Room Password Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROOM_TOKEN_SECRET=your_random_32_byte_hex_secret_here
