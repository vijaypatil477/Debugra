# Set to number of proxy hops when behind a reverse proxy (e.g. 1 for a single proxy)
# This enables Express to trust X-Forwarded-* headers for accurate client IP detection.
# Default: 0 (no proxy — use only when directly accessible)
TRUST_PROXY=0
