rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {

      // ── READ ─────────────────────────────────────────────────────────────
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;

      // ── WRITE ────────────────────────────────────────────────────────────
      // Only authenticated users (room owners) can create/update rooms.
      // passwordHash and passwordSalt can NEVER be written from the client —
      // they are set exclusively by the trusted backend via Admin SDK.
      allow create: if
        request.auth != null
        && !('passwordHash' in request.resource.data)
        && !('passwordSalt' in request.resource.data);

      allow update: if
        request.auth != null
        && request.auth.uid == resource.data.createdBy
        && !('passwordHash' in request.resource.data)
        && !('passwordSalt' in request.resource.data);

      allow delete: if
        request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // ── Public room metadata subcollection ───────────────────────────────────
    // Stores only: roomName, language, passwordProtected (bool), createdAt.
    // Safe for unauthenticated reads — no sensitive fields.
    match /rooms/{roomId}/meta/{document} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── All other collections: deny by default ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
