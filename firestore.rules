rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to access their own private collections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /rooms/{roomId} {
      // ── READ ─────────────────────────────────────────────────────────────
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // ── WRITE ────────────────────────────────────────────────────────────
      allow create: if request.auth != null
                    && !('passwordHash' in request.resource.data)
                    && !('passwordSalt' in request.resource.data);

      allow update: if request.auth != null 
                    && (
                      // Host/Creator can update anything (except writing password hash/salt from client)
                      (request.auth.uid == resource.data.createdBy && !('passwordHash' in request.resource.data) && !('passwordSalt' in request.resource.data))
                      || (
                        // Editors can update code, language, stdin, etc. but cannot modify administrative fields
                        (resource.data.roles[request.auth.uid] == 'editor' || resource.data.roles[request.auth.uid] == 'host')
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'passwordHash', 'passwordSalt', 'roles'])
                      )
                      || (
                        // Viewers can only join/leave/vote but cannot modify code, language, roles, or settings.
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['code', 'language', 'createdBy', 'passwordHash', 'passwordSalt'])
                        && (
                          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles'])
                          || (
                            request.resource.data.roles[request.auth.uid] == 'viewer'
                            && request.resource.data.roles.diff(resource.data.roles).affectedKeys().hasOnly([request.auth.uid])
                          )
                        )
                      )
                    );

      allow delete: if request.auth != null 
                    && request.auth.uid == resource.data.createdBy;

      // Subcollection for collaborative voting
      match /votes/{voteId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null 
                      && (
                        resource.data.createdBy == request.auth.uid ||
                        get(/databases/$(database)/documents/rooms/$(roomId)).data.createdBy == request.auth.uid
                      );
      }
    }

    // ── Public room metadata subcollection ───────────────────────────────────
    match /rooms/{roomId}/meta/{document} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── All other collections: deny by default ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
